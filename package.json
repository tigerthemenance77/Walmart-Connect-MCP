{
  "name": "@kobe/walmart-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for Walmart Connect Sponsored Search and Display APIs",
  "type": "module",
  "bin": {
    "walmart-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
